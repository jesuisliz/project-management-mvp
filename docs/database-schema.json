{
  "name": "project_management_mvp",
  "version": 2,
  "engine": "SQLite",
  "tables": [
    {
      "name": "users",
      "purpose": "Account identity and hashed credentials; owns zero-or-more boards.",
      "columns": [
        {
          "name": "id",
          "type": "INTEGER",
          "nullable": false,
          "generated": "SQLite rowid"
        },
        {
          "name": "username",
          "type": "TEXT",
          "nullable": false
        },
        {
          "name": "password_hash",
          "type": "TEXT",
          "nullable": false,
          "note": "Salted PBKDF2-HMAC-SHA256, formatted as 'iterations$salt_hex$hash_hex'."
        }
      ],
      "primary_key": ["id"],
      "unique_constraints": [
        {
          "name": "uq_users_username",
          "columns": ["username"]
        }
      ],
      "check_constraints": [
        {
          "name": "ck_users_username_not_blank",
          "expression": "length(trim(username)) > 0"
        }
      ],
      "foreign_keys": [],
      "indexes": [
        {
          "source": "unique_constraint",
          "columns": ["username"]
        }
      ]
    },
    {
      "name": "boards",
      "purpose": "A named board owned by a user; a user may own multiple boards.",
      "columns": [
        {
          "name": "id",
          "type": "INTEGER",
          "nullable": false,
          "generated": "SQLite rowid"
        },
        {
          "name": "user_id",
          "type": "INTEGER",
          "nullable": false
        },
        {
          "name": "name",
          "type": "TEXT",
          "nullable": false
        }
      ],
      "primary_key": ["id"],
      "unique_constraints": [],
      "check_constraints": [
        {
          "name": "ck_boards_name_not_blank",
          "expression": "length(trim(name)) > 0"
        }
      ],
      "foreign_keys": [
        {
          "columns": ["user_id"],
          "references": {
            "table": "users",
            "columns": ["id"]
          },
          "on_delete": "CASCADE"
        }
      ],
      "indexes": []
    },
    {
      "name": "columns",
      "purpose": "Fixed ordered columns with editable titles.",
      "columns": [
        {
          "name": "board_id",
          "type": "INTEGER",
          "nullable": false
        },
        {
          "name": "id",
          "type": "TEXT",
          "nullable": false
        },
        {
          "name": "position",
          "type": "INTEGER",
          "nullable": false
        },
        {
          "name": "title",
          "type": "TEXT",
          "nullable": false
        }
      ],
      "primary_key": ["board_id", "id"],
      "unique_constraints": [
        {
          "name": "uq_columns_board_position",
          "columns": ["board_id", "position"]
        }
      ],
      "check_constraints": [
        {
          "name": "ck_columns_position",
          "expression": "position >= 0 AND position < 5"
        },
        {
          "name": "ck_columns_title_not_blank",
          "expression": "length(trim(title)) > 0"
        }
      ],
      "foreign_keys": [
        {
          "columns": ["board_id"],
          "references": {
            "table": "boards",
            "columns": ["id"]
          },
          "on_delete": "CASCADE"
        }
      ],
      "indexes": [
        {
          "source": "primary_key",
          "columns": ["board_id", "id"]
        },
        {
          "source": "unique_constraint",
          "columns": ["board_id", "position"]
        }
      ]
    },
    {
      "name": "cards",
      "purpose": "Card content, owned column membership, and ordered position.",
      "columns": [
        {
          "name": "board_id",
          "type": "INTEGER",
          "nullable": false
        },
        {
          "name": "id",
          "type": "TEXT",
          "nullable": false
        },
        {
          "name": "column_id",
          "type": "TEXT",
          "nullable": false
        },
        {
          "name": "position",
          "type": "INTEGER",
          "nullable": false
        },
        {
          "name": "title",
          "type": "TEXT",
          "nullable": false
        },
        {
          "name": "details",
          "type": "TEXT",
          "nullable": false,
          "default": ""
        }
      ],
      "primary_key": ["board_id", "id"],
      "unique_constraints": [
        {
          "name": "uq_cards_column_position",
          "columns": ["board_id", "column_id", "position"]
        }
      ],
      "check_constraints": [
        {
          "name": "ck_cards_position",
          "expression": "position >= 0"
        },
        {
          "name": "ck_cards_title_not_blank",
          "expression": "length(trim(title)) > 0"
        }
      ],
      "foreign_keys": [
        {
          "columns": ["board_id"],
          "references": {
            "table": "boards",
            "columns": ["id"]
          },
          "on_delete": "CASCADE"
        },
        {
          "columns": ["board_id", "column_id"],
          "references": {
            "table": "columns",
            "columns": ["board_id", "id"]
          },
          "on_delete": "CASCADE"
        }
      ],
      "indexes": [
        {
          "source": "primary_key",
          "columns": ["board_id", "id"]
        },
        {
          "source": "unique_constraint",
          "columns": ["board_id", "column_id", "position"]
        }
      ]
    },
    {
      "name": "labels",
      "purpose": "A board-scoped catalog of colored labels.",
      "columns": [
        {
          "name": "board_id",
          "type": "INTEGER",
          "nullable": false
        },
        {
          "name": "id",
          "type": "TEXT",
          "nullable": false
        },
        {
          "name": "name",
          "type": "TEXT",
          "nullable": false
        },
        {
          "name": "color",
          "type": "TEXT",
          "nullable": false
        }
      ],
      "primary_key": ["board_id", "id"],
      "unique_constraints": [],
      "check_constraints": [
        {
          "name": "ck_labels_name_not_blank",
          "expression": "length(trim(name)) > 0"
        },
        {
          "name": "ck_labels_color_not_blank",
          "expression": "length(trim(color)) > 0"
        }
      ],
      "foreign_keys": [
        {
          "columns": ["board_id"],
          "references": {
            "table": "boards",
            "columns": ["id"]
          },
          "on_delete": "CASCADE"
        }
      ],
      "indexes": [
        {
          "source": "primary_key",
          "columns": ["board_id", "id"]
        }
      ]
    },
    {
      "name": "card_labels",
      "purpose": "Join table assigning labels to cards, both scoped to the same board.",
      "columns": [
        {
          "name": "board_id",
          "type": "INTEGER",
          "nullable": false
        },
        {
          "name": "card_id",
          "type": "TEXT",
          "nullable": false
        },
        {
          "name": "label_id",
          "type": "TEXT",
          "nullable": false
        }
      ],
      "primary_key": ["board_id", "card_id", "label_id"],
      "unique_constraints": [],
      "check_constraints": [],
      "foreign_keys": [
        {
          "columns": ["board_id", "card_id"],
          "references": {
            "table": "cards",
            "columns": ["board_id", "id"]
          },
          "on_delete": "CASCADE"
        },
        {
          "columns": ["board_id", "label_id"],
          "references": {
            "table": "labels",
            "columns": ["board_id", "id"]
          },
          "on_delete": "CASCADE"
        }
      ],
      "indexes": [
        {
          "source": "primary_key",
          "columns": ["board_id", "card_id", "label_id"]
        }
      ]
    }
  ],
  "service_invariants": {
    "one_board_per_user": false,
    "last_board_deletion": "Rejected; every user must retain at least one board.",
    "fixed_column_ids": [
      "col-backlog",
      "col-discovery",
      "col-progress",
      "col-review",
      "col-done"
    ],
    "fixed_column_count": 5,
    "column_mutations": ["rename"],
    "card_positions": "Zero-based and contiguous within each column after every committed mutation.",
    "identifiers": "Column, card, and label IDs are stable and scoped to a board. Board IDs are stable integers scoped to a user.",
    "timestamps": "Omitted because no MVP behavior consumes them.",
    "ai_operations": "The AI may create, edit, and move/reorder cards only; it cannot manage boards, columns, or labels."
  },
  "initialization": {
    "mvp_username": "user",
    "mvp_seed_password": "password",
    "template": "docs/sample-board.json",
    "rule": "Create the seeded demo user (with the demo cards) if absent; self-registered users get one empty board with the fixed columns and no demo cards. Never reseed an existing board."
  },
  "storage": {
    "configuration": "DATABASE_PATH",
    "container_path": "/app/data/pm.db",
    "compose_volume_mount": "/app/data"
  }
}
